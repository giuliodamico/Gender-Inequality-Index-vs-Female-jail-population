# =============================================================
# Data files (raw data should be kept; large processed files
# may be excluded from version control)
# =============================================================
# Uncomment to exclude large raw data files from git:
# data/raw/*.csv
# data/raw/*.xlsx
# data/raw/*.json

# Always exclude heavyweight binary formats if very large:
*.parquet
*.feather
*.pkl
*.h5
*.hdf5

